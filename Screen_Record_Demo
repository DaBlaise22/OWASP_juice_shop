// ---- In-browser stand-in for server.js, using the SAME logic ----
(async function () {
  const seedHash = await new Promise((resolve) => {
    dcodeIO.bcrypt.hash('CorrectHorse123', 12, (err, hash) => resolve(hash));
  });
  const users = [{ email: 'demo@juice-shop-assignment.test', password_hash: seedHash }];

  function isValidLoginPayload(body) {
    if (!body || typeof body.email !== 'string' || typeof body.password !== 'string') return false;
    const email = body.email.trim();
    if (email.length === 0 || email.length > 254) return false;
    if (!email.includes('@')) return false;
    if (body.password.length < 8 || body.password.length > 128) return false;
    return true;
  }

  const realFetch = window.fetch;
  window.fetch = function (url, opts) {
    if (url !== '/api/login') return realFetch(url, opts);
    return new Promise((resolve) => {
      const body = JSON.parse(opts.body);
      if (!isValidLoginPayload(body)) {
        return resolve({ ok: false, json: async () => ({ message: 'Invalid email or password format.' }) });
      }
      const email = body.email.trim();
      // parameterized-equivalent lookup: exact literal match, never re-interpreted as code
      const user = users.find(u => u.email === email);
      const genericFail = () => resolve({ ok: false, json: async () => ({ message: 'Invalid email or password.' }) });
      if (!user) return genericFail();
      dcodeIO.bcrypt.compare(body.password, user.password_hash, (err, match) => {
        if (err || !match) return genericFail();
        resolve({ ok: true, json: async () => ({ message: `Welcome back, ${user.email}!` }) });
      });
    });
  };
})();
</script>
